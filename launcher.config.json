{
  "appId": "forge-world-launcher",
  "launcherVersion": "3.0",
  "distributionVersion": "3.0.3",
  "branding": {
    "projectName": "FORGE WORLD",
    "subtitle": [
      "Погрузись в мир, где честь — редкость,",
      "а сила решает судьбы."
    ]
  },
  "minecraft": {
    "version": "1.21.1",
    "neoForgeVersion": "21.1.229",
    "defaultVersionId": "neoforge-21.1.229",
    "instanceFolderName": "forge-world-instance",
    "defaultRamMb": 6144,
    "minimumRamMb": 3072,
    "maximumRamMb": 16384,
    "minimumLaunchRamMb": 2048,
    "directConnectOnLaunch": true,
    "server": {
      "host": "forgeworld.joinserver.ru",
      "port": 25684,
      "displayName": "Forge World"
    }
  },
  "links": {
    "site": "https://github.com/iron-halo-team/forgeworld",
    "discord": "https://discord.gg/sBJQqKtB",
    "wiki": "https://github.com/iron-halo-team/forgeworld/wiki",
    "github": "https://github.com/iron-halo-team/forgeworld"
  },
  "update": {
    "metadataUrl": "https://raw.githubusercontent.com/iron-halo-team/forgeworld/main/updates/metadata.json",
    "downloadPage": "https://github.com/iron-halo-team/forgeworld/blob/main/updates/download.md"
  },
  "content": {
    "remoteUrl": "https://raw.githubusercontent.com/iron-halo-team/forgeworldlauncher/master/content/launcher-content.json",
    "checkIntervalMs": 5000
  },
  "auth": {
    "enabled": true,
    "baseUrl": "http://f10.joinserver.xyz:25833",
    "fallbackBaseUrl": "http://f10.joinserver.xyz:25797",
    "hostHeader": "",
    "requestTimeoutMs": 12000
  },
  "preserveOnUpdate": [
    "options.txt",
    "optionsof.txt",
    "saves",
    "screenshots",
    "resourcepacks",
    "shaderpacks",
    "logs"
  ]
